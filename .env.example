# --- Contact form (Resend) ---------------------------------------------------
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender. Until you verify a domain, you can use Resend's sandbox:
CONTACT_FROM_EMAIL="Contact <onboarding@resend.dev>"
# Where contact messages are delivered (defaults to siteConfig email if unset):
CONTACT_TO_EMAIL=hmnajam@gmail.com

# --- On-site assistant "Virtual Najam" (POST /api/chat) ----------------------
# Provider is swappable via the Vercel AI SDK; default is Google Gemini.
CHAT_MODEL_PROVIDER=google
# Optional model override (defaults to gemini-2.5-flash):
# CHAT_MODEL=gemini-2.5-flash
# Get a free-tier key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Lead capture reuses the Resend vars above (RESEND_API_KEY / CONTACT_TO_EMAIL).

# --- Analytics ---------------------------------------------------------------
# Google Analytics 4 Measurement ID (format G-XXXXXXXXXX). Loaded only when set.
# Create a GA4 property at https://analytics.google.com → Admin → Data Streams.
NEXT_PUBLIC_GA_ID=

# --- Blog publishing API (POST /api/blog) ------------------------------------
# Shared secret clients must send as `Authorization: Bearer <token>`:
BLOG_API_TOKEN=
# A GitHub fine-grained PAT with Contents: read & write on this repo:
GITHUB_TOKEN=
GITHUB_REPO_OWNER=hmnajam
GITHUB_REPO_NAME=najamdotpk
GITHUB_BRANCH=main